# GLM — environment configuration
# Copy to .env and fill in actual values; .env is gitignored.

# --- Server -----------------------------------------------------------------
# Port the Bun process listens on
PORT=3000
# 'development' | 'test' | 'production'
NODE_ENV=development

# --- Auth -------------------------------------------------------------------
# HMAC secret for signing 7-day session cookies. Generate with:
#   bun -e "console.log(crypto.randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-me-with-32-bytes-of-hex

# Solo-mode bearer token (docs/solo-mode-spec.md §5.3). Any HTTP request with
# `Authorization: Bearer <this>` is accepted as the deterministic 'solo' user.
# Generated and stored by `glm init`; run `glm init --write-env` to populate
# this line automatically.
# GLM_SOLO_TOKEN=

# --- Persistence ------------------------------------------------------------
# Path to the SQLite DB file for this organization (one DB per org).
GLM_DB_PATH=./data/glm.db

# --- Git layer --------------------------------------------------------------
# Path to the sekkei git repository (YAML files + ECN commits live here).
SEKKEI_REPO_PATH=./repos/glm-sekkei
# Path to the realization git repository (generated artifacts land here).
REALIZATION_REPO_PATH=./repos/glm-realization

# --- LLM provider -----------------------------------------------------------
# Anthropic API key for the generation pipeline. Optional in dev/test.
ANTHROPIC_API_KEY=
# Default model for generation; Sonnet 4.6 unless overridden per-generator.
ANTHROPIC_MODEL=claude-sonnet-4-6
